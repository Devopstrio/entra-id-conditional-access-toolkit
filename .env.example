# --- Backend ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/toolkit_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=supersecret

# --- Microsoft Entra ID Credentials ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Toolkit Configuration ---
PROJECT_NAME=entra-id-toolkit
ENVIRONMENT=dev
DB_PASSWORD=
LOCATION=eastus

# --- Feature Toggles ---
ENABLE_SSO=true
ENABLE_MULTI_TENANT=true
ENABLE_REPORT_ONLY_MODE=true
ENABLE_PASSWORDLESS=true
ENABLE_DEFENDER_INTEGRATION=true
ENABLE_SENTINEL_EXPORT=true
ENABLE_GRAPH_SYNC=true
